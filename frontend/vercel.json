{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/faq", "destination": "/frequently-asked-questions", "statusCode": 301 },
    { "source": "/agents", "destination": "/", "statusCode": 301 },
    { "source": "/agent-hub", "destination": "/", "statusCode": 301 },
    { "source": "/agent-toolkit", "destination": "/", "statusCode": 301 },
    { "source": "/agent-toolkit/admin", "destination": "/", "statusCode": 301 },
    { "source": "/for-agents", "destination": "/", "statusCode": 301 },
    { "source": "/dealsync", "destination": "/", "statusCode": 301 },
    { "source": "/real-estate-agents", "destination": "/", "statusCode": 301 },
    { "source": "/realtor-tools", "destination": "/", "statusCode": 301 },
    { "source": "/realtor-tools/:path*", "destination": "/", "statusCode": 301 }
  ]
}
