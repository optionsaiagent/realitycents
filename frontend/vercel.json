{
  "buildCommand": "pnpm run build && node scripts/prerender.mjs",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/faq",
      "destination": "/frequently-asked-questions",
      "statusCode": 301
    },
    {
      "source": "/agent-hub",
      "destination": "/agents",
      "statusCode": 301
    },
    {
      "source": "/agent-toolkit",
      "destination": "/agents",
      "statusCode": 301
    },
    {
      "source": "/agent-toolkit/admin",
      "destination": "/agents",
      "statusCode": 301
    },
    {
      "source": "/for-agents",
      "destination": "/agents",
      "statusCode": 301
    },
    {
      "source": "/dealsync",
      "destination": "/agents",
      "statusCode": 301
    },
    {
      "source": "/real-estate-agents",
      "destination": "/agents",
      "statusCode": 301
    },
    {
      "source": "/realtor-tools",
      "destination": "/agents",
      "statusCode": 301
    },
    {
      "source": "/realtor-tools/:path*",
      "destination": "/agents",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/s/:code",
      "destination": "https://realitycents-production.up.railway.app/r/:code"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "framework": "vite"
}